# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace_with_a_long_random_secret
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=farshad
N8N_BASIC_AUTH_PASSWORD=replace_me
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Europe/Berlin

# Database
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_me

# Optional API keys used by workflows
OPENAI_API_KEY=replace_me
OPENAI_SCORING_MODEL=gpt-5-mini

# Optional Upwork URL polling intake.
# Use newline- or comma-separated saved search URLs or an allowed intermediary URL.
# Later this branch can be replaced by Apify.
UPWORK_POLL_URLS=

# Optional later broad-market source
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
SERPAPI_API_KEY=replace_me

# Optional later Apify integration
APIFY_TOKEN=
APIFY_UPWORK_ACTOR_ID=
